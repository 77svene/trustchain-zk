{
  "name": "trustchain-zk-reputation",
  "version": "1.0.0",
  "description": "Zero-Knowledge proof system for AI agent reputation: Circom-generated task completion proofs mint Soulbound Tokens on-chain, enabling trust-minimized multi-agent delegation without KYC",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "zk:compile": "circom circuits/task.circom --r1cs --wasm --sym",
    "zk:prove": "node scripts/generate_proof.js",
    "zk:verify": "node scripts/verify_proof.js"
  },
  "dependencies": {
    "circomlib": "2.0.5",
    "ethers": "6.13.4",
    "zksync-ethers": "5.9.1",
    "circom_runtime": "2.0.5"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.2",
    "ts-node": "10.9.2",
    "jest": "29.7.0",
    "@types/jest": "29.5.14"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/varakh/trustchain"
  },
  "keywords": [
    "zero-knowledge",
    "zk-snarks",
    "circom",
    "agent-reputation",
    "soulbound-token",
    "multi-agent-systems",
    "trust-minimized"
  ],
  "license": "MIT"
}